{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel 2>/dev/null)/.claude/hooks/checkpoint-reminder.sh\"",
            "timeout": 15,
            "statusMessage": "Checking for uncommitted checkpoints..."
          },
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel 2>/dev/null)/.claude/hooks/auto-install.sh\"",
            "timeout": 120,
            "statusMessage": "Installing canopy..."
          }
        ]
      }
    ]
  }
}
